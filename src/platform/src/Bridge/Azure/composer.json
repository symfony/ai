{
    "name": "symfony/ai-azure-platform",
    "description": "Azure AI platform bridge for Symfony AI",
    "license": "MIT",
    "type": "symfony-ai-platform",
    "keywords": ["ai", "azure", "azure-openai", "bridge", "platform"],
    "authors": [
        {
            "name": "Christopher Hertel",
            "email": "mail@christopher-hertel.de"
        },
        {
            "name": "Oskar Stark",
            "email": "oskarstark@googlemail.com"
        },
        {
            "name": "Symfony Community",
            "homepage": "https://symfony.com/contributors"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/ai-platform": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5.13"
    },
    "minimum-stability": "dev",
    "autoload": {
        "psr-4": {
            "Symfony\\AI\\Platform\\Bridge\\Azure\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfony\\AI\\Platform\\Bridge\\Azure\\Tests\\": "Tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.x-dev"
        },
        "thanks": {
            "name": "symfony/ai",
            "url": "https://github.com/symfony/ai"
        }
    }
}
