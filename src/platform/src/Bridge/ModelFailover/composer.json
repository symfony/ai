{
    "name": "symfony/ai-model-failover-platform",
    "description": "Model failover platform bridge for Symfony AI",
    "license": "MIT",
    "type": "symfony-ai-platform",
    "keywords": [
        "ai",
        "bridge",
        "platform",
        "failover",
        "model"
    ],
    "authors": [
        {
            "name": "Kevin Mauel",
            "email": "kevin.mauel2+github@gmail.com"
        },
        {
            "name": "Symfony Community",
            "homepage": "https://symfony.com/contributors"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/ai-platform": "^0.6"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.5.53"
    },
    "minimum-stability": "dev",
    "autoload": {
        "psr-4": {
            "Symfony\\AI\\Platform\\Bridge\\ModelFailover\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfony\\AI\\PHPStan\\": "../../../../../.phpstan/",
            "Symfony\\AI\\Platform\\Bridge\\ModelFailover\\Tests\\": "Tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "thanks": {
            "name": "symfony/ai",
            "url": "https://github.com/symfony/ai"
        }
    }
}
